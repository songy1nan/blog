---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '还真是',
  description = '一点生活、自然、阅读与思考的记录。',
} = Astro.props;

const pageTitle = title === '还真是' ? title : `${title} | 还真是`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>还真是</a>
      <nav aria-label="主导航">
        <a href={base}>首页</a>
        <a href={`${base}blog/`}>文章</a>
        <a href={`${base}about/`}>关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© {new Date().getFullYear()} 还真是</span>
      <span>写给经过的风，也写给朋友看</span>
    </footer>
  </body>
</html>
